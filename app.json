{
  "expo": {
    "name": "Ninhao",
    "slug": "ninhao-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ninhao",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.oliinyki.ninhao",
      "associatedDomains": ["applinks:ninhao.com"],
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to quickly and securely sign in to Ninhao."
      }
    },
    "android": {
      "package": "com.oliinyki.ninhao",
      "adaptiveIcon": {
        "backgroundColor": "#FF6B00",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "ninhao.com",
              "pathPrefix": "/product"
            },
            {
              "scheme": "https",
              "host": "ninhao.com",
              "pathPrefix": "/category"
            },
            {
              "scheme": "https",
              "host": "ninhao.com",
              "pathPrefix": "/seller"
            },
            {
              "scheme": "https",
              "host": "ninhao.com",
              "pathPrefix": "/search"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-image",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      "./plugins/withPodfileDeploymentTarget.js",
      "./plugins/withPrivacyManifest.js",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
